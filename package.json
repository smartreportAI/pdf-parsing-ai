{
    "name": "pdf-parser-backend",
    "version": "1.0.0",
    "description": "Parses lab PDFs with Vertex AI Gemini and sends structured data to Smart Report Engine",
    "main": "dist/index.js",
    "scripts": {
        "build": "tsc",
        "start": "node dist/index.js",
        "dev": "ts-node-dev --respawn --transpile-only src/index.ts"
    },
    "engines": {
        "node": ">=18"
    },
    "dependencies": {
        "@google-cloud/vertexai": "^1.9.3",
        "axios": "^1.6.8",
        "cors": "^2.8.5",
        "dotenv": "^16.4.5",
        "express": "^4.19.2",
        "multer": "^1.4.5-lts.1"
    },
    "devDependencies": {
        "@types/cors": "^2.8.17",
        "@types/express": "^4.17.21",
        "@types/multer": "^1.4.11",
        "@types/node": "^20.12.7",
        "ts-node-dev": "^2.0.0",
        "typescript": "^5.4.5"
    }
}