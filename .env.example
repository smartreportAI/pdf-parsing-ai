# ── Local development ─────────────────────────────────────────────────────────

PORT=4000

# Your Google Cloud project ID
GOOGLE_PROJECT_ID=niro-471913

# Vertex AI region (this is where Gemini runs)
GOOGLE_LOCATION=us-central1

# Path to your service account key file (LOCAL ONLY — never commit this file)
# Download from GCP Console → IAM → Service Accounts → your account → Keys
GOOGLE_APPLICATION_CREDENTIALS=./gcp-key.json

# URL of the Smart Report Engine running locally
SMART_REPORT_ENGINE_URL=http://localhost:3000

# Optional: tenantId in API response (default: "demo")
# TENANT_ID=demo

# Optional: max tokens for Gemini output (Gemini 2.0 Flash max: 8192)
# GEMINI_MAX_OUTPUT_TOKENS=8192


# ── Render deployment — Option A: Secret File
#
# 1. In Render → Secret Files: add a file named "gcp-key.json" with the full JSON key contents.
# 2. For native Node services, Render mounts Secret Files in the SERVICE ROOT. Set:
#
#      Key:   GOOGLE_APPLICATION_CREDENTIALS
#      Value: gcp-key.json
#
#    (If that fails, try: /etc/secrets/gcp-key.json . The app will also try both paths automatically.)
# 3. Keep GOOGLE_PROJECT_ID and GOOGLE_LOCATION set.
#
# ── Render deployment — Option B: JSON in env var (most reliable, no path issues)
#
#   Key:   GOOGLE_CREDENTIALS_JSON
#   Value: The ENTIRE service account JSON minified to ONE line (no newlines).
#
# After deploy, test: GET https://your-app.onrender.com/auth-check
